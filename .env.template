# Supabase — Next.js app uses NEXT_PUBLIC_* (Expo uses EXPO_PUBLIC_*; align both in monorepos)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Service Role Key (for admin operations - KEEP SECRET!)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Payment Gateway Keys (replace with your actual keys)
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_YourTestKeyHere
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YourStripeKeyHere

# Next.js web (ChaseDue dashboard + /pay/[invoiceId])
# Billing: Razorpay Payment Link or hosted subscription URL (opened from /dashboard/billing & landing “Get Pro”)
NEXT_PUBLIC_CHASEDUE_PRO_CHECKOUT_URL=
NEXT_PUBLIC_CHASEDUE_AGENCY_CHECKOUT_URL=
# Razorpay: create-order prefers NEXT_PUBLIC_RAZORPAY_KEY_ID, then legacy RAZORPAY_KEY_ID; secret is server-only
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_YourTestKeyHere
RAZORPAY_KEY_ID=rzp_test_YourTestKeyHere
RAZORPAY_KEY_SECRET=your_razorpay_secret
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Landing FAQ: digits only (no +) for wa.me link, e.g. 9198xxxxxxxx — enables “Chat on WhatsApp”
NEXT_PUBLIC_SUPPORT_WHATSAPP_DIGITS=

# Portal — global checkout (USD): PayPal Smart Buttons + optional Lemon Squeezy link
# INR per 1 USD — display + PayPal order amount (update periodically)
NEXT_PUBLIC_INR_PER_USD=83
# Browser: PayPal JS SDK (sandbox or live client id from developer.paypal.com)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_sandbox_or_live_client_id
# Server: PayPal REST OAuth — never expose to client (alias: PAYPAL_SECRET)
PAYPAL_CLIENT_ID=your_sandbox_or_live_client_id
PAYPAL_CLIENT_SECRET=your_paypal_secret
# NEXT_PUBLIC_PAYPAL_ENV=sandbox
# PAYPAL_ENV=live
# Optional override (defaults: sandbox api-m.sandbox.paypal.com, live api-m.paypal.com)
# PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
# Lemon Squeezy — prefer full checkout URL:
# NEXT_PUBLIC_LEMON_SQUEEZY_CHECKOUT_URL=https://your-store.lemonsqueezy.com/checkout/buy/123456
# Or build from:
# (B) Store subdomain + variant (same as Lemon dashboard) — avoids 404 placeholder links
NEXT_PUBLIC_LEMON_SQUEEZY_STORE_ID=your-store
NEXT_PUBLIC_LEMON_SQUEEZY_VARIANT_ID=123456
# Optional alias for store subdomain: NEXT_PUBLIC_LEMON_SQUEEZY_STORE=your-store

# WhatsApp Chase links: https://chasedue.com/portal/[invoiceId] (override for local: http://localhost:3000)
NEXT_PUBLIC_CHASE_PORTAL_ORIGIN=https://chasedue.com

# Public client portal header — business / freelancer name
NEXT_PUBLIC_BUSINESS_DISPLAY_NAME=A. Sathish Kumar

# Expense tracker: monthly budget in INR for "Remaining budget" (paise = INR × 100 in app)
NEXT_PUBLIC_EXPENSE_MONTHLY_BUDGET_INR=50000

# Dashboard: confetti + toast when monthly paid total (INR) crosses this threshold
NEXT_PUBLIC_REVENUE_MILESTONE_INR=10000

# Cron / automation: GET or POST /api/check-reminders (Bearer or ?secret=)
CRON_SECRET=generate_a_long_random_string

# Meta WhatsApp Cloud API (webhook: GET verify + POST events → /api/webhooks/whatsapp)
META_WHATSAPP_VERIFY_TOKEN=your_random_verify_token
META_APP_SECRET=your_meta_app_secret

# Email Configuration
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=noreply@flowfinance.app

# Invoice PDF (fallbacks when profile fields are empty — prefer GST/address in Supabase `profiles`)
NEXT_PUBLIC_INVOICE_SELLER_NAME=
NEXT_PUBLIC_INVOICE_SELLER_GSTIN=
NEXT_PUBLIC_INVOICE_SELLER_STATE_CODE=
NEXT_PUBLIC_INVOICE_SELLER_ADDRESS=
NEXT_PUBLIC_INVOICE_SELLER_EMAIL=
NEXT_PUBLIC_INVOICE_SELLER_PHONE=
NEXT_PUBLIC_INVOICE_BANK_ACCOUNT_NAME=
NEXT_PUBLIC_INVOICE_BANK_ACCOUNT_NUMBER=
NEXT_PUBLIC_INVOICE_BANK_IFSC=
NEXT_PUBLIC_INVOICE_BANK_NAME=
